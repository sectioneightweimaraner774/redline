  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/check.mjs\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
